<?xml version="1.0" encoding="utf-8"?>
<!--
  widget_layout_v2.xml
  Used by KuralWidgetProvider (Phase 3).
  The Kural text is rendered as a Bitmap by WidgetBitmapRenderer
  and displayed in widget_image. Only the action buttons remain as
  native RemoteViews children (bitmap rendering cannot intercept button taps).
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root_v2"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- Rendered Kural bitmap card -->
    <ImageView
        android:id="@+id/widget_image"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:adjustViewBounds="true"
        android:scaleType="fitXY"
        android:contentDescription="Kural widget" />

    <!-- Action buttons overlaid at top-right, aligned with header -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:orientation="horizontal"
        android:paddingTop="8dp"
        android:paddingEnd="16dp">

        <TextView
            android:id="@+id/btn_share"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:text="↗"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginEnd="8dp"
            android:contentDescription="Share this kural" />

        <TextView
            android:id="@+id/btn_prev"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:text="←"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginEnd="8dp"
            android:contentDescription="Previous kural" />

        <TextView
            android:id="@+id/btn_random"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:text="⟳"
            android:textSize="16sp"
            android:gravity="center"
            android:contentDescription="Random kural" />

    </LinearLayout>

</FrameLayout>
