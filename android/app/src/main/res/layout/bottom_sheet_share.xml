<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#171717"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="32dp">

        <!-- Handle -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:background="#303030"
            android:layout_marginBottom="24dp" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Choose content to share"
            android:textColor="#F5F5F5"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select what you'd like to include"
            android:textColor="#A0A0A0"
            android:textSize="13sp"
            android:layout_marginBottom="24dp" />

        <!-- ── Options ──────────────────────────────────────────────────────── -->

        <CheckBox
            android:id="@+id/cb_tamil_kural"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tamil Kural"
            android:textColor="#F5F5F5"
            android:textSize="15sp"
            android:checked="true"
            android:paddingStart="8dp"
            android:layout_marginBottom="4dp" />

        <CheckBox
            android:id="@+id/cb_english"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="English Translation"
            android:textColor="#F5F5F5"
            android:textSize="15sp"
            android:paddingStart="8dp"
            android:layout_marginBottom="4dp" />

        <CheckBox
            android:id="@+id/cb_kalaignar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kalaignar Explanation"
            android:textColor="#F5F5F5"
            android:textSize="15sp"
            android:checked="true"
            android:paddingStart="8dp"
            android:layout_marginBottom="4dp" />

        <CheckBox
            android:id="@+id/cb_varadarajan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mu. Varadarajan Explanation"
            android:textColor="#F5F5F5"
            android:textSize="15sp"
            android:paddingStart="8dp"
            android:layout_marginBottom="4dp" />

        <CheckBox
            android:id="@+id/cb_solomon"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Solomon Pappaiya Explanation"
            android:textColor="#F5F5F5"
            android:textSize="15sp"
            android:paddingStart="8dp"
            android:layout_marginBottom="4dp" />

        <CheckBox
            android:id="@+id/cb_attribution"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Include attribution"
            android:textColor="#A0A0A0"
            android:textSize="14sp"
            android:checked="true"
            android:paddingStart="8dp"
            android:layout_marginBottom="24dp" />

        <!-- ── Preview ──────────────────────────────────────────────────────── -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PREVIEW"
            android:textColor="#606060"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/share_preview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#222222"
            android:padding="16dp"
            android:textColor="#A0A0A0"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.5"
            android:layout_marginBottom="24dp" />

        <!-- ── Continue button ──────────────────────────────────────────────── -->

        <Button
            android:id="@+id/btn_share_continue"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Continue"
            android:textColor="#0F0F0F"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="#F5F5F5"
            android:stateListAnimator="@null" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
