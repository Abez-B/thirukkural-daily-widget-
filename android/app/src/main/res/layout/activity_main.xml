<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_main.xml — Thirukkural Daily Dashboard
  Design: monochromatic, reader-first. No blue accents.
  Inspiration: Readwise Reader, Kindle, Notion.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0F0F0F">

    <!-- ── Status bar spacer ──────────────────────────────────────────────── -->
    <View
        android:id="@+id/status_bar_spacer"
        android:layout_width="match_parent"
        android:layout_height="0dp" />

    <!-- ── Scrollable content ─────────────────────────────────────────────── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="32dp"
            android:paddingBottom="120dp">

            <!-- ── Header: Icon + Wordmark ──────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="36dp">

                <!-- App Logo -->
                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@mipmap/ic_launcher"
                    android:layout_marginEnd="16dp"
                    android:contentDescription="App Logo" />

                <!-- App wordmark -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="திருக்குறள்"
                        android:textColor="#F5F5F5"
                        android:textSize="26sp"
                        android:fontFamily="serif"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DAILY"
                        android:textColor="#505050"
                        android:textSize="10sp"
                        android:letterSpacing="0.25" />
                </LinearLayout>
            </LinearLayout>

            <!-- ── Widget preview section ──────────────────────────────────── -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="WIDGET PREVIEW"
                android:textColor="#505050"
                android:textSize="10sp"
                android:letterSpacing="0.12"
                android:layout_marginBottom="12dp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="36dp">

                <ImageView
                    android:id="@+id/main_preview_image"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:adjustViewBounds="true"
                    android:scaleType="fitXY"
                    android:visibility="gone"
                    android:contentDescription="Widget preview" />

                <ProgressBar
                    android:id="@+id/main_preview_loading"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center"
                    android:indeterminateTint="#505050"
                    android:layout_marginTop="32dp"
                    android:layout_marginBottom="32dp" />

            </FrameLayout>

            <!-- ── Today's Kural card ──────────────────────────────────────── -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="DISPLAYED KURAL"
                android:textColor="#505050"
                android:textSize="10sp"
                android:letterSpacing="0.12"
                android:layout_marginBottom="12dp" />

            <!-- Kural number + Paal breadcrumb -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/main_kural_num"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#F5F5F5"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="#222222"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp" />

                <TextView
                    android:id="@+id/main_paal"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:textColor="#A0A0A0"
                    android:textSize="12sp" />

            </LinearLayout>

            <!-- Kural couplet — primary visual focus -->
            <TextView
                android:id="@+id/main_kural_line1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#F5F5F5"
                android:textSize="19sp"
                android:fontFamily="serif"
                android:lineSpacingMultiplier="1.4" />

            <TextView
                android:id="@+id/main_kural_line2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#F5F5F5"
                android:textSize="19sp"
                android:fontFamily="serif"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="36dp" />

            <!-- ── Action buttons ──────────────────────────────────────────── -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <Button
                    android:id="@+id/btn_view_detail"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="52dp"
                    android:text="Read"
                    android:textColor="#0F0F0F"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:backgroundTint="#F5F5F5"
                    android:layout_marginEnd="8dp"
                    android:stateListAnimator="@null" />

                <Button
                    android:id="@+id/btn_share_main"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="52dp"
                    android:text="Share"
                    android:textColor="#F5F5F5"
                    android:textSize="14sp"
                    android:backgroundTint="#222222"
                    android:stateListAnimator="@null" />

            </LinearLayout>

            <Button
                android:id="@+id/btn_customize"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Customize Widget"
                android:textColor="#A0A0A0"
                android:textSize="14sp"
                android:backgroundTint="#171717"
                android:stateListAnimator="@null" />

            <!-- ── Footer ─────────────────────────────────────────────────── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#222222"
                android:layout_marginTop="48dp"
                android:layout_marginBottom="24dp" />

            <TextView
                android:id="@+id/btn_website"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="bharath.is-cool.dev"
                android:textColor="#808080"
                android:textSize="12sp"
                android:gravity="center"
                android:background="?android:attr/selectableItemBackground"
                android:padding="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/btn_contribute"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Contribute"
                    android:textColor="#808080"
                    android:textSize="12sp"
                    android:background="?android:attr/selectableItemBackground"
                    android:padding="8dp"
                    android:layout_marginEnd="16dp" />

                <TextView
                    android:id="@+id/btn_issues"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Report Issues"
                    android:textColor="#808080"
                    android:textSize="12sp"
                    android:background="?android:attr/selectableItemBackground"
                    android:padding="8dp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
