<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#171717">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="32dp">

        <!-- Handle -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:background="#303030"
            android:layout_marginBottom="24dp" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Customize Widget"
            android:textColor="#F5F5F5"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Changes reflect immediately on the widget"
            android:textColor="#505050"
            android:textSize="12sp"
            android:layout_marginBottom="28dp" />

        <!-- ── Live Preview ───────────────────────────────────────────────── -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PREVIEW"
            android:textColor="#404040"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:layout_marginBottom="12dp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp">

            <ImageView
                android:id="@+id/preview_image"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:scaleType="fitXY"
                android:contentDescription="Widget preview" />

            <ProgressBar
                android:id="@+id/preview_loading"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:indeterminateTint="#404040"
                android:visibility="gone" />

        </FrameLayout>

        <!-- ── Fonts ─────────────────────────────────────────────────────── -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FONT"
            android:textColor="#404040"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:layout_marginBottom="12dp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:id="@+id/font_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />

        </HorizontalScrollView>

        <!-- ── Themes ─────────────────────────────────────────────────────── -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="THEME"
            android:textColor="#404040"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:layout_marginBottom="12dp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:id="@+id/theme_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />

        </HorizontalScrollView>

        <!-- ── Appearance ─────────────────────────────────────────────────── -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="APPEARANCE"
            android:textColor="#404040"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Font Size"
            android:textColor="#A0A0A0"
            android:textSize="13sp"
            android:layout_marginBottom="4dp" />

        <com.google.android.material.slider.Slider
            android:id="@+id/slider_font_size"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="10"
            android:valueTo="28"
            android:stepSize="1"
            app:thumbColor="#F5F5F5"
            app:trackColorActive="#F5F5F5"
            app:trackColorInactive="#2A2A2A"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Opacity"
            android:textColor="#A0A0A0"
            android:textSize="13sp"
            android:layout_marginBottom="4dp" />

        <com.google.android.material.slider.Slider
            android:id="@+id/slider_opacity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="0.3"
            android:valueTo="1.0"
            android:stepSize="0.05"
            app:thumbColor="#F5F5F5"
            app:trackColorActive="#F5F5F5"
            app:trackColorInactive="#2A2A2A"
            android:layout_marginBottom="32dp" />

        <!-- ── Meanings (SAVE pattern) ────────────────────────────────────── -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="MEANINGS"
                android:textColor="#404040"
                android:textSize="10sp"
                android:letterSpacing="0.12" />

            <Button
                android:id="@+id/btn_save_commentaries"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Save Meanings"
                android:textColor="#0F0F0F"
                android:textSize="12sp"
                android:backgroundTint="#F5F5F5"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:stateListAnimator="@null"
                android:alpha="0.4" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tap SAVE after making selections."
            android:textColor="#383838"
            android:textSize="11sp"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:id="@+id/commentary_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="32dp" />

        <!-- ── Advanced ───────────────────────────────────────────────────── -->

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#222222"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btn_reset_defaults"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Reset to Defaults"
            android:textColor="#C0392B"
            android:textSize="13sp"
            android:backgroundTint="#2D0E0A"
            android:stateListAnimator="@null" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
