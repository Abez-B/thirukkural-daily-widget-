<resources>
    <style name="Theme.ThirukuralDaily" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Monochromatic surface system -->
        <item name="colorPrimary">@color/dark_text_primary</item>
        <item name="colorPrimaryVariant">@color/dark_surface2</item>
        <item name="colorSecondary">@color/dark_text_secondary</item>
        <item name="colorSurface">@color/dark_surface</item>
        <item name="android:colorBackground">@color/dark_bg</item>
        <item name="colorOnPrimary">@color/dark_bg</item>
        <item name="colorOnSurface">@color/dark_text_primary</item>
        <item name="colorOnBackground">@color/dark_text_primary</item>

        <!-- No status bar tint — window draws behind it -->
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/dark_bg</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Shape system: rounded everywhere -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeSmall</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeMedium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeLarge</item>

        <!-- Typography: system sans-serif (Tamil rendering safe) -->
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- Shape tokens -->
    <style name="ShapeSmall" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerSize">8dp</item>
    </style>
    <style name="ShapeMedium" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerSize">16dp</item>
    </style>
    <style name="ShapeLarge" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerSize">24dp</item>
    </style>

    <!-- Button styles -->
    <style name="Widget.Kural.PrimaryButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/dark_text_primary</item>
        <item name="android:textColor">@color/dark_bg</item>
        <item name="cornerRadius">100dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="Widget.Kural.SecondaryButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/dark_surface2</item>
        <item name="android:textColor">@color/dark_text_primary</item>
        <item name="cornerRadius">100dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="Widget.Kural.OutlinedButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/dark_border</item>
        <item name="android:textColor">@color/dark_text_secondary</item>
        <item name="cornerRadius">100dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:textSize">14sp</item>
    </style>

    <!-- Card style -->
    <style name="Widget.Kural.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/dark_surface</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/dark_border</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Bottom sheet -->
    <style name="Widget.Kural.BottomSheet" parent="Widget.MaterialComponents.BottomSheet">
        <item name="shapeAppearance">@style/ShapeLarge</item>
        <item name="backgroundTint">@color/dark_surface</item>
    </style>

    <!-- Section header text -->
    <style name="TextAppearance.Kural.SectionHeader" parent="TextAppearance.AppCompat">
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">@color/dark_text_secondary</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <!-- Kural couplet display text -->
    <style name="TextAppearance.Kural.Couplet" parent="TextAppearance.AppCompat">
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/dark_text_primary</item>
        <item name="android:lineSpacingMultiplier">1.5</item>
        <item name="android:fontFamily">serif</item>
    </style>

    <!-- Explanation body text -->
    <style name="TextAppearance.Kural.Body" parent="TextAppearance.AppCompat">
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/dark_text_secondary</item>
        <item name="android:lineSpacingMultiplier">1.6</item>
    </style>
</resources>
